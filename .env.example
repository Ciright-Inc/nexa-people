# Ciright login (same values for local + production if you share one env set)
NEXA_CIRIGHT_LIVE_AUTH=true

# =============================================================================
# SHARED DATABASE (local + Railway production)
# =============================================================================
# This app is Next.js (not Spring Boot). Site data uses DATABASE_URL + the `pg`
# driver — there is no application.yml or Hibernate.
#
# 1. Railway → PostgreSQL → Connect → copy DATABASE_URL
# 2. Railway → your WEB service → Variables → set DATABASE_URL (same value)
# 3. Local: copy .env.local.example → .env.local and paste the SAME DATABASE_URL
#
# When DATABASE_URL is set, both environments read/write table:
#   public.personal_sites_state (single JSONB row, id = 1)
#
# When DATABASE_URL is missing locally, dev falls back to:
#   data/personal-sites.json  ← NOT shared with production
#
# DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Optional: only when DATABASE_URL is NOT set (isolated local file)
# PERSONAL_SITES_DATA_PATH=./data/personal-sites.json
