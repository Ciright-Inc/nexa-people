# Ciright login (same values for local + production if you share one env set)
NEXA_CIRIGHT_LIVE_AUTH=true

# Personal sites — REQUIRED for local and production to share the same site list.
# Add a PostgreSQL database on Railway (or Neon/Supabase), then paste the same URL here
# and in Railway → your web service → Variables.
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Optional: only used when DATABASE_URL is not set (local-only JSON file; not shared with production)
# PERSONAL_SITES_DATA_PATH=./data/personal-sites.json
