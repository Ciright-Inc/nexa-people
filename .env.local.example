# Copy this file to .env.local (gitignored) and fill in values.
# Use the SAME DATABASE_URL as Railway → your web service → Variables.

NEXA_CIRIGHT_LIVE_AUTH=true

# Railway → PostgreSQL → Connect → copy DATABASE_URL (paste the FULL string, not YOUR_PASSWORD)
# Example shape only — use your real URL from Railway:
# DATABASE_URL=postgresql://postgres:xxxx@xxxx.proxy.rlwy.net:12345/railway
DATABASE_URL=

# Do NOT set PERSONAL_SITES_DATA_PATH when using shared Postgres.
# That path forces a separate local JSON file (not synced with production).
